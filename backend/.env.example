# OpenRouter (key starts with sk-or-v1-). Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=
# Model id on OpenRouter (must match an enabled model in your account)
# Valid examples: google/gemini-2.0-flash-001, google/gemini-2.5-flash (see openrouter.ai/models)
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Optional: Google Gemini direct API (used by /api/chat only)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

PORT=5001

# Optional: your dev app URL (OpenRouter may check Referer). Match the port Vite uses (3000, 3002, …)
# OPENROUTER_SITE_URL=http://localhost:3002
